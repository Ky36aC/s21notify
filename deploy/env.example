# s21notify — скопировать в /opt/s21notify/.env и заполнить (chmod 600!)
# Секреты генерировать так:  openssl rand -base64 32

BIND_ADDR=0.0.0.0:80
PUBLIC_URL=https://s21notify.tobitrix.ru
STATIC_DIR=/opt/s21notify/static
DATABASE_URL=sqlite:///opt/s21notify/data/s21notify.db

# base64, ровно 32 байта — шифрование offline-токенов. ПОТЕРЯ КЛЮЧА = все
# пользователи перелогиниваются заново.
ENCRYPTION_KEY=
JWT_SECRET=

ENABLED_MESSENGERS=telegram,max

# @s21notify_bot — токен от BotFather
TG_BOT_TOKEN=
TG_WEBHOOK_SECRET=

# MAX s21notify (id482618491734_4_bot) — токен из кабинета dev.max.ru
MAX_BOT_TOKEN=
MAX_WEBHOOK_SECRET=
MAX_API_URL=https://platform-api2.max.ru
# 0 = слать в MAX без HTML (если проверка живьём покажет, что HTML не рендерится)
MAX_HTML=1

POLL_INTERVAL_SEC=90
DEADLINE_POLL_EVERY=10
MAX_CONCURRENT_POLLS=8
PLATFORM_RPS=5

# личный chat_id владельца у @s21notify_bot — алерты о сломанном whitelist
ADMIN_TG_CHAT_ID=

RUST_LOG=info,sqlx=warn
