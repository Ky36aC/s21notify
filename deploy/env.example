# s21notify — server-режим (общий сервис). Скопировать в /opt/s21notify/.env
# и заполнить (chmod 600!). Под каждым полем написано, откуда брать значение.
# Для локального запуска на своём ПК используй deploy/local.env.example.

# server (по умолчанию) — мультипользовательский сервис; local — single-user на ПК.
APP_MODE=server

# --- сеть ---
# Что слушает сервис внутри машины (порт 80 требует CAP_NET_BIND_SERVICE — он есть в юните).
BIND_ADDR=0.0.0.0:80
# ОБЯЗАТЕЛЬНО (в server-режиме). Публичный https-URL сервиса — его открывает
# кнопка miniapp внутри мессенджера, и на него же приходят вебхуки (если включены).
# Твой домен, проброшенный на этот сервис. Пример: https://s21notify.example.com
PUBLIC_URL=

# --- пути (при каталоге /opt/s21notify можно не трогать) ---
STATIC_DIR=/opt/s21notify/static
DATABASE_URL=sqlite:///opt/s21notify/data/s21notify.db

# --- секреты, которые генеришь сам ---
# Ключ шифрования offline-токенов. Сгенерировать:  openssl rand -base64 32
# ПОТЕРЯ КЛЮЧА = все пользователи логинятся заново.
ENCRYPTION_KEY=
# Подпись JWT-сессий miniapp. Сгенерировать:  openssl rand -base64 32
JWT_SECRET=

# Включённые мессенджеры (оставь только те, чьи токены заполнил ниже).
ENABLED_MESSENGERS=telegram,max

# Как боты получают апдейты: polling (по умолчанию) или webhook.
# polling — бот сам ходит к API, НЕ нужен домен/входящие порты (работает в РФ и локально).
# webhook — нужен публичный https + PUBLIC_URL + *_WEBHOOK_SECRET ниже; для масштаба.
TG_TRANSPORT=polling
MAX_TRANSPORT=polling

# --- Telegram ---
# Токен бота от @BotFather (https://t.me/BotFather → /newbot, либо /token для готового).
TG_BOT_TOKEN=
# Секрет вебхука (нужен только при TG_TRANSPORT=webhook) — openssl rand -hex 16
# Telegram присылает его в заголовке X-Telegram-Bot-Api-Secret-Token, сервис сверяет.
TG_WEBHOOK_SECRET=

# --- MAX ---
# Токен бота из кабинета разработчика https://dev.max.ru
MAX_BOT_TOKEN=
# Секрет вебхука (нужен только при MAX_TRANSPORT=webhook) — openssl rand -hex 16
# У MAX нет заголовка-секрета, поэтому он уходит прямо в query вебхука (?s=...).
MAX_WEBHOOK_SECRET=
# База MAX API — менять не нужно.
MAX_API_URL=https://platform-api2.max.ru
# 1 = слать в MAX с HTML; поставь 0, если проверка живьём покажет, что HTML не рендерится.
MAX_HTML=1

# --- опрос платформы (дефолты обычно менять не нужно) ---
POLL_INTERVAL_SEC=90
DEADLINE_POLL_EVERY=10
MAX_CONCURRENT_POLLS=8
PLATFORM_RPS=5

# Твой личный chat_id в Telegram — туда идут алерты (напр. о сломанном GraphQL-whitelist).
# Узнать id: напиши боту @userinfobot — он ответит числом.
ADMIN_TG_CHAT_ID=

RUST_LOG=info,sqlx=warn
